PROJECT_NAME           = "Fluvel"
PROJECT_BRIEF          = "Active contour image processing engine"

IMAGE_PATH = docs/images
HTML_EXTRA_FILES = docs/images/fluvel.svg

INPUT                  = src README.md
RECURSIVE              = YES

OUTPUT_DIRECTORY       = docs
HTML_OUTPUT = html
CREATE_SUBDIRS         = NO

USE_MDFILE_AS_MAINPAGE = README.md

FILE_PATTERNS          = *.hpp *.cpp *.md

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO

GENERATE_HTML          = YES
GENERATE_LATEX         = NO

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO

GENERATE_TREEVIEW      = YES
FULL_PATH_NAMES        = NO

SOURCE_BROWSER         = NO
INLINE_SOURCES         = NO

HAVE_DOT               = YES

CLASS_DIAGRAMS         = YES
COLLABORATION_GRAPH    = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES

DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES

DOT_GRAPH_MAX_NODES    = 50

