PROJECT_NAME           = "Fluvel"
PROJECT_BRIEF          = "Active contour image processing engine"

IMAGE_PATH = docs/images
HTML_EXTRA_FILES = docs/images

INPUT                  = src docs/mainpage.md
RECURSIVE              = YES

INCLUDE_PATH = src
EXCLUDE_PATTERNS = */build/* */.qt/* */moc_*

OUTPUT_DIRECTORY       = docs
HTML_OUTPUT = html
CREATE_SUBDIRS         = NO

USE_MDFILE_AS_MAINPAGE = docs/mainpage.md

FILE_PATTERNS          = *.hpp *.cpp *.md

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = NO

GENERATE_HTML          = YES
GENERATE_LATEX         = NO

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO

GENERATE_TREEVIEW      = YES
FULL_PATH_NAMES        = NO

SOURCE_BROWSER         = NO
INLINE_SOURCES         = NO

HAVE_DOT               = YES

CLASS_DIAGRAMS         = YES
COLLABORATION_GRAPH    = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES

DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES

DOT_MULTI_TARGETS      = YES
UML_LOOK               = YES

DOT_GRAPH_MAX_NODES    = 50

INLINE_INFO            = YES
ALWAYS_DETAILED_SEC    = YES

