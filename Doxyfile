    docs/theme/upstream/doxygen-awesome.css \
    docs/theme/upstream/doxygen-awesome-sidebar-only-darkmode-toggle.css \
    docs/theme/upstream/doxygen-awesome-sidebar-only.css \
    docs/theme/fluvel.css

