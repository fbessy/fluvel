{
  "id": "org.fluvel.App",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.9",
  "sdk": "org.kde.Sdk",
  "command": "fluvel",

  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=dri",
    "--device=all"
  ],

  "modules": [

    {
      "name": "fluvel",
      "buildsystem": "cmake-ninja",
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DFLUVEL_BUILD_VERSION=__APP_VERSION__",
        "-DFLUVEL_GIT_COMMIT=__CI_COMMIT__",
        "-DFLUVEL_BUILD_TIMESTAMP=__BUILD_TIMESTAMP__",
        "-DFLUVEL_BUILD_ORIGIN=__BUILD_ORIGIN__"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    },

    {
      "name": "fluvel-metadata",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm644 packaging/linux/org.fluvel.App.desktop /app/share/applications/org.fluvel.App.desktop",
        "install -Dm644 metainfo.ci.xml /app/share/metainfo/org.fluvel.App.metainfo.xml",
        "install -Dm644 packaging/linux/org.fluvel.App.svg /app/share/icons/hicolor/scalable/apps/org.fluvel.App.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "__SOURCE_ROOT__"
        }
      ]
    }

  ]
}
