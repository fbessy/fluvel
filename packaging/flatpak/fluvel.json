{
  "id": "org.fluvel.Fluvel",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.9",
  "sdk": "org.kde.Sdk",
  "command": "fluvel",
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=dri",
    "--device=all"
  ],
  "modules": [
    {
      "name": "fluvel",
      "buildsystem": "cmake-ninja",
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DFLUVEL_BUILD_VERSION=__APP_VERSION__",
        "-DFLUVEL_GIT_COMMIT=__CI_COMMIT__",
        "-DFLUVEL_BUILD_TIMESTAMP=__BUILD_TIMESTAMP__",
        "-DFLUVEL_BUILD_ORIGIN=__BUILD_ORIGIN__"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    },
    {
      "name": "fluvel-metadata",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm644 packaging/linux/org.fluvel.Fluvel.desktop /app/share/applications/org.fluvel.Fluvel.desktop",
        "install -Dm644 metainfo.ci.xml /app/share/metainfo/org.fluvel.Fluvel.metainfo.xml",
        "install -Dm644 packaging/linux/org.fluvel.Fluvel.svg /app/share/icons/hicolor/scalable/apps/org.fluvel.Fluvel.svg",
        "install -Dm644 resources/icons/app/fluvel-64.png /app/share/icons/hicolor/64x64/apps/org.fluvel.Fluvel.png",
        "install -Dm644 resources/icons/app/fluvel-128.png /app/share/icons/hicolor/128x128/apps/org.fluvel.Fluvel.png",
        "install -Dm644 resources/icons/app/fluvel-256.png /app/share/icons/hicolor/256x256/apps/org.fluvel.Fluvel.png"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "__SOURCE_ROOT__"
        }
      ]
    }
  ]
}