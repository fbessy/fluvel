{
  "id": "org.fluvel.App",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.9",
  "sdk": "org.kde.Sdk",
  "command": "Fluvel",

  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=dri",
    "--device=all"
  ],

  "modules": [
    {
      "name": "fluvel",
      "buildsystem": "cmake-ninja",
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DFLUVEL_BUILD_ORIGIN=GitLab Runner",
        "-DFLUVEL_GIT_COMMIT=__CI_COMMIT__"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "../.."
        }
      ]
    }
  ]
}
