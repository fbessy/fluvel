<?xml version="1.0" encoding="UTF-8"?>

<component type="desktop-application">

  <id>org.fluvel.Fluvel</id>

  <name>Fluvel</name>
  <name xml:lang="fr">Fluvel</name>

  <summary>
    Real-time computer vision and image analysis for research
  </summary>

  <summary xml:lang="fr">
    Vision par ordinateur et analyse d’image en temps réel pour la recherche
  </summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>CECILL-2.1-only</project_license>

  <content_rating type="oars-1.1"/>

  <description>

    <p>
      Fluvel is a research-oriented image segmentation application designed
      for fast and efficient experimentation with level-set active contour methods.
    </p>

    <p>
      It provides real-time image processing, video stream support,
      pre-processing tools, and quantitative evaluation metrics such as
      Hausdorff distance for segmentation analysis.
    </p>

    <p xml:lang="fr">
      Fluvel est une application de segmentation d’image orientée recherche,
      conçue pour des expérimentations rapides et efficaces avec des méthodes
      de contours actifs basées sur les ensembles de niveaux.
    </p>

    <p xml:lang="fr">
      Elle propose un traitement d’image en temps réel, la gestion de flux vidéo,
      des outils de prétraitement ainsi que des métriques d’évaluation
      quantitatives telles que la distance de Hausdorff pour l’analyse
      de segmentation.
    </p>

  </description>

  <categories>
    <category>Science</category>
    <category>Graphics</category>
  </categories>

  <launchable type="desktop-id">
    org.fluvel.Fluvel.desktop
  </launchable>

  <developer id="org.fluvel">
    <name>Fabien Bessy</name>
  </developer>

  <url type="homepage">
    https://fbessy.github.io/fluvel
  </url>

  <url type="vcs-browser">
    https://github.com/fbessy/fluvel
  </url>

  <releases>
    <release version="@PROJECT_VERSION@"
             date="@FLUVEL_RELEASE_DATE@"/>
  </releases>

  <screenshots>

    <screenshot type="default">
      <image>
        https://fbessy.github.io/fluvel/assets/images/segmentation-start.webp
      </image>
    </screenshot>

    <screenshot>
      <image>
        https://fbessy.github.io/fluvel/assets/images/segmentation-result.webp
      </image>
    </screenshot>

    <screenshot>
      <image>
        https://fbessy.github.io/fluvel/assets/images/settings.webp
      </image>
    </screenshot>

  </screenshots>

</component>
