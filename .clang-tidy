Checks: >
  clang-analyzer-*,
  bugprone-*,
  performance-*,
  modernize-use-nullptr,
  modernize-use-override,
  modernize-use-default-member-init,
  modernize-use-static-cast,
  readability-identifier-naming,
  -bugprone-narrowing-conversions,
  misc-unused-includes,
  modernize-use-forward-declaration

WarningsAsErrors: ''

HeaderFilterRegex: 'src/.*'

CheckOptions:

  # === Naming rules ===

  # Namespaces → lower_case
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case

  # Classes → PascalCase
  - key: readability-identifier-naming.ClassCase
    value: PascalCase

  # Structs → PascalCase
  - key: readability-identifier-naming.StructCase
    value: PascalCase

  # Enums → PascalCase
  - key: readability-identifier-naming.EnumCase
    value: PascalCase

  # Enum values → PascalCase (Qt-style)
  - key: readability-identifier-naming.EnumConstantCase
    value: PascalCase

  # Type aliases (using / typedef) → PascalCase
  - key: readability-identifier-naming.TypeAliasCase
    value: PascalCase

  # Functions → camelCase
  - key: readability-identifier-naming.FunctionCase
    value: camelCase

  # Methods → camelCase
  - key: readability-identifier-naming.MethodCase
    value: camelCase

  # Variables locales → camelCase
  - key: readability-identifier-naming.VariableCase
    value: camelCase

  # Paramètres → camelCase
  - key: readability-identifier-naming.ParameterCase
    value: camelCase

  # Membres privés → camelCase_
  - key: readability-identifier-naming.PrivateMemberCase
    value: camelCase
  - key: readability-identifier-naming.PrivateMemberSuffix
    value: _

  # Membres protégés → camelCase_
  - key: readability-identifier-naming.ProtectedMemberCase
    value: camelCase
  - key: readability-identifier-naming.ProtectedMemberSuffix
    value: _

  # Membres publics → camelCase
  - key: readability-identifier-naming.PublicMemberCase
    value: camelCase

  # Constantes globales → kConstantCase
  - key: readability-identifier-naming.GlobalConstantPrefix
    value: k
  - key: readability-identifier-naming.GlobalConstantCase
    value: CamelCase

  # Macros → UPPER_CASE
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
