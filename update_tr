#!/usr/bin/env bash
# update_translations.sh
# Met à jour tous les fichiers .ts et génère les .qm correspondants

set -e

# Chemin vers le binaire Qt (à adapter si besoin)
QT_BIN="/home/fabien/Qt/6.10.1/gcc_64/bin"

# Répertoire racine du projet (où est ce script)
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Répertoires sources à scanner pour les traductions
SRC_DIRS=("src/app" "src/image_processing")

# Répertoire des fichiers de traduction
TS_DIR="$ROOT_DIR/translations"
mkdir -p "$TS_DIR"

# Construire la liste des chemins relatifs des sources
SRC_PATHS=()
for dir in "${SRC_DIRS[@]}"; do
    SRC_PATHS+=("$ROOT_DIR/$dir")
done

# Parcourir tous les fichiers .ts dans le dossier translations
for ts_file in "$TS_DIR"/*.ts; do
    [ -e "$ts_file" ] || continue  # Skip if no .ts file found
    qm_file="${ts_file%.ts}.qm"

    echo "➡️  Mise à jour $ts_file"
    "$QT_BIN/lupdate" "${SRC_PATHS[@]}" -ts "$ts_file"

    echo "➡️  Compilation en $qm_file"
    "$QT_BIN/lrelease" "$ts_file"
done

echo "✅ Toutes les traductions mises à jour"
